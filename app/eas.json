{
  "cli": {
    "version": ">= 12.14.1",
    "appVersionSource": "remote",
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "buildConfiguration": "Debug"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "BUILD_TYPE": "development",
        "CLINICAL_VALIDATION": "true",
        "NEW_ARCHITECTURE": "true"
      }
    },
    "preview": {
      "extends": "production",
      "distribution": "internal",
      "env": {
        "BUILD_TYPE": "preview",
        "CLINICAL_VALIDATION": "true",
        "WELLNESS_MONITORING_ENABLED": "true",
        "PERFORMANCE_MONITORING": "true",
        "NEW_ARCHITECTURE": "true",
        "CRISIS_MONITORING": "true",
        "EXPO_PUBLIC_API_URL": "http://localhost:3000",
        "EXPO_PUBLIC_SUPABASE_URL": "$SUPABASE_URL_STAGING"
      },
      "cache": {
        "disabled": false,
        "cacheDefaultPaths": true
      }
    },
    "production": {
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "resourceClass": "m1-medium"
      },
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "medium"
      },
      "env": {
        "BUILD_TYPE": "production",
        "CLINICAL_VALIDATION": "true",
        "WELLNESS_MONITORING_ENABLED": "true",
        "PERFORMANCE_MONITORING": "true",
        "NEW_ARCHITECTURE": "true",
        "CRISIS_MONITORING": "true",
        "PRODUCTION_MONITORING": "true",
        "WELLNESS_DATA_PROTECTION": "true",
        "WELLNESS_PRACTICES_MONITORING": "true"
      },
      "cache": {
        "disabled": false,
        "cacheDefaultPaths": true,
        "customPaths": [
          "app/node_modules"
        ]
      }
    },
    "production-emergency": {
      "extends": "production",
      "distribution": "store",
      "env": {
        "BUILD_TYPE": "production",
        "EMERGENCY_DEPLOYMENT": "true",
        "CRISIS_OVERRIDE": "true",
        "WELLNESS_MONITORING_ENABLED": "true",
        "PERFORMANCE_MONITORING": "true",
        "NEW_ARCHITECTURE": "true",
        "PRODUCTION_MONITORING": "true",
        "WELLNESS_DATA_PROTECTION": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "PLACEHOLDER_APP_ID",
        "appleTeamId": "PLACEHOLDER_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./android-service-account.json",
        "track": "production",
        "releaseStatus": "completed"
      }
    },
    "preview": {
      "ios": {
        "ascAppId": "PLACEHOLDER_APP_ID",
        "appleTeamId": "PLACEHOLDER_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./android-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
