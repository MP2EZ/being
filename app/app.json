{
  "expo": {
    "name": "Being",
    "slug": "being",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "description": "Evidence-based Stoic Mindfulness practices for mental wellness and virtue development.",
    "primaryColor": "#4A7C59",
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "being",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.being.app",
      "buildNumber": "2",
      "icon": "./assets/icon.png",
      "deploymentTarget": "16.4",
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:being.fyi",
        "applinks:www.being.fyi"
      ]
    },
    "android": {
      "package": "com.being.app",
      "versionCode": 2,
      "icon": "./assets/icon.png",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "being.fyi",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.being.fyi",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Being",
      "shortName": "Being"
    },
    "plugins": [
      "expo-localization",
      [
        "./plugins/withAppGroupsEntitlement",
        {
          "groups": ["group.com.being.app.widgets"]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "extra": {
      "clinicalVersion": "1.0",
      "buildType": "production",
      "eas": {
        "projectId": "8229e873-3c06-41fc-a8cf-48a45fa76316"
      }
    },
    "owner": "palouselabs"
  }
}
