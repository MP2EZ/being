{
  "name": "app",
  "version": "1.0.1",
  "main": "index.ts",
  "scripts": {
    "generate:legal-content": "node scripts/generate-legal-content.js",
    "prestart": "npm run generate:legal-content",
    "preios": "npm run generate:legal-content",
    "preandroid": "npm run generate:legal-content",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "test:ci": "jest --coverage --ci --watchAll=false --forceExit",
    "test:clinical": "jest --testPathPattern=clinical --verbose --forceExit",
    "test:crisis-detection": "jest --testPathPattern=\"(crisis-safety-automation|crisis-intervention-safety|crisis-thresholds|offline-crisis-management|CollapsibleCrisisButton.behavioral|CrisisSecurityProtocol)\" --verbose --testTimeout=30000 --forceExit",
    "test:unit": "jest --testPathPattern=unit --forceExit",
    "test:safety": "jest --testPathPattern=\"(__tests__/safety|__tests__/crisis-safety)\" --verbose --forceExit",
    "test:edge-functions": "cd ../supabase/functions && deno task test",
    "test:integration": "jest --testPathPattern=integration --verbose --forceExit",
    "test:performance": "jest --testPathPattern=performance --verbose --forceExit",
    "test:accessibility": "jest --testPathPattern=accessibility --verbose --forceExit",
    "test:security": "jest --testPathPattern=security --verbose --forceExit --detectOpenHandles",
    "test:encryption": "jest --testPathPattern=EncryptionService --verbose",
    "test:crisis-quick": "jest --testPathPattern=\"[Cc]risis\" --ci --silent --testTimeout=5000 --maxWorkers=4",
    "test:clinical-quick": "JEST_QUICK=true jest --testNamePattern=\"clinical|phq|gad\"",
    "test:offline": "jest --testPathPattern=offline --verbose --testTimeout=60000",
    "test:offline-crisis": "jest --testPathPattern=\"offline-crisis\" --testNamePattern=\"Offline Crisis Management\" --verbose --testTimeout=30000",
    "validate:clinical": "npm run test:clinical && echo '✅ Clinical accuracy tests passed'",
    "validate:accessibility": "npm run test:accessibility && echo '✅ Accessibility tests passed'",
    "validate:performance": "npm run test:performance && echo '✅ Performance tests passed'",
    "validate:clinical-complete": "npm run test:clinical && echo '✅ Complete clinical accuracy validation passed'",
    "validate:crisis-authority": "npm run test:crisis-quick && echo '✅ Crisis Authority validation passed'",
    "validate:compliance-authority": "npm run test:encryption && echo '✅ Compliance Authority validation passed'",
    "validate:clinical-authority": "npm run validate:clinical-complete && echo '✅ Clinical Authority validation passed'",
    "validate:offline-crisis": "npm run test:offline-crisis && echo '✅ Offline crisis management validation passed'",
    "automation:quick": "node scripts/local-test-automation.js quick",
    "automation:full": "node scripts/local-test-automation.js comprehensive",
    "automation:performance": "node scripts/local-test-automation.js performance",
    "automation:pre-commit": "node scripts/local-test-automation.js pre-commit",
    "automation:dev": "node scripts/local-test-automation.js development",
    "automation:watch": "node scripts/local-test-automation.js watch",
    "local:validate": "npm run automation:quick && echo '✅ Local validation complete'",
    "local:crisis-check": "npm run test:crisis-quick && echo '✅ Crisis safety validation complete'",
    "local:clinical-check": "npm run test:clinical && npm run validate:clinical-complete && echo '✅ Clinical accuracy validation complete'",
    "reports:dashboard": "node scripts/test-report-generator.js dashboard",
    "reports:performance": "node scripts/test-report-generator.js performance",
    "reports:coverage": "node scripts/test-report-generator.js coverage",
    "reports:all": "node scripts/test-report-generator.js all",
    "quick:validate": "node scripts/quick-validation.js smart",
    "quick:crisis": "node scripts/quick-validation.js crisis",
    "quick:clinical": "node scripts/quick-validation.js clinical",
    "quick:syntax": "node scripts/quick-validation.js syntax",
    "quick:perf": "node scripts/quick-validation.js performance",
    "quick:fix": "node scripts/quick-validation.js fix",
    "quick:watch": "node scripts/quick-validation.js watch",
    "quick:interactive": "node scripts/quick-validation.js interactive",
    "dev:test-smart": "node scripts/dev-test-runner.js smart",
    "dev:test-focused": "node scripts/dev-test-runner.js focused",
    "dev:test-debug": "node scripts/dev-test-runner.js debug",
    "dev:test-fast": "node scripts/dev-test-runner.js fast",
    "dev:test-coverage": "node scripts/dev-test-runner.js coverage",
    "platform:list": "node scripts/cross-platform-testing.js list",
    "platform:ios": "node scripts/cross-platform-testing.js ios",
    "platform:android": "node scripts/cross-platform-testing.js android",
    "platform:both": "node scripts/cross-platform-testing.js both",
    "platform:setup": "node scripts/cross-platform-testing.js setup",
    "platform:parallel": "node scripts/cross-platform-testing.js both --parallel",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:baseline": "node scripts/lint-baseline.js",
    "lint:clinical": "eslint --max-warnings=0 src/core/analytics/PostHogProvider.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "npx tsc --noEmit --incremental",
    "precommit": "npm run typecheck && npm run lint:baseline && npm run test:safety && npm run test:clinical && npm run test:unit",
    "check:crisis-hotline": "node scripts/check-crisis-hotline.js",
    "prepare": "[ ! -e ../.git ] && exit 0; cd .. && husky app/.husky",
    "postinstall": "patch-package && node scripts/generate-legal-content.js",
    "prepush": "npm run check:crisis-hotline",
    "version-check": "node -e \"const pkg=require('./package.json'); if(pkg.dependencies.react !== '19.2.3') throw new Error('React must be 19.2.3 for RN 0.85.x compatibility')\"",
    "security:sast": "echo \"🔍 Running SAST Analysis...\" && audit-ci --config .audit-ci.json && echo \"✅ SAST Analysis completed\"",
    "security:deps": "npm audit --audit-level high",
    "security:full": "npm run security:sast && npm run security:deps",
    "deploy:validate-rollback": "echo \"🔄 Validating rollback safety...\" && node -e \"console.log('Rollback validation would run here in production')\"",
    "e2e:safety": "maestro test .maestro/ --include-tags=safety",
    "e2e:safety:q9": "maestro test .maestro/q9-single-alert.yaml",
    "e2e:safety:phq9": "maestro test .maestro/phq9-severe-completion.yaml",
    "e2e:safety:gad7": "maestro test .maestro/gad7-severe.yaml",
    "e2e:safety:crisis-button": "maestro test .maestro/crisis-button-reachability.yaml",
    "e2e:safety:988-dial": "maestro test .maestro/crisis-988-dial.yaml"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  },
  "overrides": {
    "react": "19.2.3",
    "react-test-renderer": "19.2.3",
    "@types/react": "19.2.14"
  },
  "resolutions": {
    "react": "19.2.3",
    "react-test-renderer": "19.2.3",
    "@types/react": "19.2.14"
  },
  "dependencies": {
    "@mp2ez/being-design-system": "^1.8.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-community/slider": "5.2.0",
    "@react-native-picker/picker": "^2.11.4",
    "@react-native-vector-icons/ionicons": "13.1.2",
    "@react-native-vector-icons/material-design-icons": "13.1.2",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/stack": "^7.4.8",
    "@sentry/react-native": "~7.11.0",
    "@stripe/stripe-react-native": "0.64.0",
    "@supabase/supabase-js": "^2.39.3",
    "expo": "~56.0.0",
    "expo-apple-authentication": "~56.0.4",
    "expo-application": "~56.0.3",
    "expo-asset": "~56.0.14",
    "expo-auth-session": "~56.0.11",
    "expo-build-properties": "~56.0.14",
    "expo-crypto": "~56.0.3",
    "expo-dev-client": "~56.0.15",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-local-authentication": "~56.0.4",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.13",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "posthog-react-native": "^4.17.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-aes-crypto": "^3.2.1",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-iap": "^15.3.1",
    "react-native-keychain": "^10.0.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3",
    "react-test-renderer": "19.2.3",
    "uuid": "^13.0.0",
    "zod": "^4.1.13",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.8",
    "@types/node": "^24.3.1",
    "@types/react": "19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "audit-ci": "^7.1.0",
    "babel-preset-expo": "~56.0.0",
    "eslint": "^9.34.0",
    "eslint-config-universe": "^15.0.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "patch-package": "^8.0.1",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
